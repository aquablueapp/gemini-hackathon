{
  "name": "api",
  "type": "module",
  "version": "1.0.0",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./client": {
      "types": "./dist/client/src/client.d.ts",
      "default": "./dist/client/src/client.js"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "dev:local": "cross-env NODE_ENV=development bun run --hot src/index.ts",
    "dev": "bun run dev:local",
    "start": "bun ./dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "test": "NODE_ENV=test vitest",
    "build": "bun run build:server && bun run build:client",
    "db:seed": "cross-env NODE_ENV=development bun run scripts/seed.ts",
    "build:server": "tsc && tsc-alias",
    "build:client": "tsc -p tsconfig.client.json && tsc-alias -p tsconfig.client.json"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/storage": "^7.21.0",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^1.3.0",
    "@scalar/hono-api-reference": "^0.9.48",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^12.0.3",
    "hono": "^4.12.14",
    "hono-pino": "^0.10.3",
    "parse-diff": "^0.12.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stoker": "2.0.1",
    "web-tree-sitter": "^0.26.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@faker-js/faker": "^10.4.0",
    "@sentry/cli": "^3.4.1",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^1.5.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
