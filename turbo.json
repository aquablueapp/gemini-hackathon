{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DEPLOY_TARGET"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**", ".vinxi/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build:client": {
      "dependsOn": ["^build"],
      "outputs": ["dist/client/**"]
    }
  }
}
